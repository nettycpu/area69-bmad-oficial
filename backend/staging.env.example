# Copy these keys into your staging host secret manager. Do not commit real values.
RAILS_ENV=production
RACK_ENV=production
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=5

SECRET_KEY_BASE=replace_with_rails_secret
JWT_SECRET=replace_with_another_rails_secret
DATABASE_URL=postgresql://user:password@host:5432/area69_staging

FRONTEND_BASE_URL=https://app-staging.example.com
ALLOWED_ORIGINS=https://app-staging.example.com

STRIPE_API_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
STRIPE_PRICE_50_CREDITS=price_replace
STRIPE_PRICE_150_CREDITS=price_replace
STRIPE_PRICE_300_CREDITS=price_replace
STRIPE_PRICE_600_CREDITS=price_replace

HIGGSFIELD_API_KEY=replace
HIGGSFIELD_API_SECRET=replace
WAVESPEED_API_KEY=replace

CREDITS_SECRET=replace_with_long_random_secret
INTERNAL_SECRET=replace_with_long_random_secret

R2_PUBLIC_URL_HOST=https://media-staging.example.com
R2_BUCKET=area69-staging
R2_ENDPOINT=https://replace.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace
R2_SECRET_ACCESS_KEY=replace
